# Public site URL (used for metadata, OG images, canonical).
# On Vercel, set this per-environment.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# GitHub PAT (fine-grained, read-only contents on noureddinestam/dofus-companion).
# Lifts the 60 req/h public rate limit to 5000 req/h. Server-only, never exposed.
GITHUB_TOKEN=""

# VirusTotal v3 API key (free tier, 4 req/min). Server-only.
VIRUSTOTAL_API_KEY=""
