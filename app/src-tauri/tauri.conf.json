{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dofus Companion",
  "version": "0.4.1",
  "identifier": "com.dofus-companion.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dofus Companion",
        "width": 520,
        "height": 720,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3MjQ4Qjg2Q0RCOTk2MzgKUldRNGxybk5ob3NrTjlsVE80Y3NibmpJSVlqYmlHQTdFTGd1dzdnT2dJMWFobmtURGFVaWRwbVMK",
      "endpoints": [
        "https://github.com/noureddinestam/dofus-companion/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "publisher": "noureddinestam",
    "copyright": "Copyright (c) 2026 noureddinestam. MIT license.",
    "homepage": "https://dofuscompanion.com",
    "category": "Utility",
    "shortDescription": "Overlay Windows open source pour Dofus — 185 donjons, strategies FR/EN.",
    "longDescription": "Dofus Companion is an unofficial open source overlay for Dofus: 185 dungeons, bilingual FR/EN strategies, readable-in-10-seconds short form. No memory reading, no automation, no tracker. MIT license, source at https://github.com/noureddinestam/dofus-companion.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false
      }
    }
  }
}
