{
  "name": "dofus-companion",
  "version": "0.4.2",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter app tauri dev",
    "build": "pnpm --filter app tauri build",
    "lint": "pnpm --filter app lint && pnpm --filter scraper lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter app test && pnpm --filter scraper test && pnpm --filter dofus-companion-web test",
    "scrape": "pnpm --filter scraper scrape",
    "web:dev": "pnpm --filter dofus-companion-web dev",
    "web:build": "pnpm --filter dofus-companion-web build",
    "web:test": "pnpm --filter dofus-companion-web test"
  }
}
